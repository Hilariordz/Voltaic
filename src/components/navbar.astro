<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-4 sm:px-6 md:px-12 py-3 md:py-4 bg-white/95 backdrop-blur-md border-b border-on-surface border-opacity-20">
  <div class="flex items-center h-12">
    <a href="/" class="h-full block">
      <img src="/src/assets/hyw.svg" alt="Logo Hanval & Walker" class="h-full w-auto">
    </a>
  </div>

  <button id="menu-btn" class="flex flex-col justify-between w-6 h-4 md:hidden cursor-pointer focus:outline-none" aria-label="Abrir menú">
    <span class="w-full h-[2px] bg-primary"></span>
    <span class="w-full h-[2px] bg-primary"></span>
    <span class="w-full h-[2px] bg-primary"></span>
  </button>

  <nav class="hidden md:flex space-x-6 lg:space-x-10">
    <a class="font-body-md text-body-md font-semibold text-primary border-b-2 border-primary pb-1" href="#identity">Identidad</a>
    <a class="font-body-md text-body-md font-semibold text-on-surface-variant hover:text-primary transition-colors nav-underline" href="#values">Valores</a>
    <a class="font-body-md text-body-md font-semibold text-on-surface-variant hover:text-primary transition-colors nav-underline" href="#services">Servicios</a>
    
  </nav>

  <a href="#contact" class="hidden md:flex [background-color:#2E3132] [color:#F3F4F6] px-4 py-2 md:px-6 md:py-2.5 rounded font-label-sm text-label-sm uppercase tracking-widest hover:bg-black hover:text-white transition-colors font-bold items-center justify-center">
    Consultar con Expertos
  </a>

  <div id="mobile-menu" class="hidden fixed inset-0 top-[72px] w-full h-[calc(100vh-72px)] bg-white md:hidden flex-col p-6 justify-between items-center border-t border-gray-100 shadow-xl">
  
  <nav class="flex flex-col space-y-6 pt-12 text-center w-full">
    <a class="font-body-md text-xl font-semibold text-primary mobile-link" href="#identity">Identidad</a>
    <a class="font-body-md text-xl font-semibold text-on-surface-variant mobile-link" href="#values">Valores</a>
    <a class="font-body-md text-xl font-semibold text-on-surface-variant mobile-link" href="#services">Servicios</a>
  </nav>
  
  <a href="#contact" class="w-full [background-color:#2E3132] [color:#F3F4F6] py-3.5 rounded font-label-sm text-label-sm uppercase tracking-widest text-center font-bold block mobile-link">
    Consultar con Expertos
  </a>
</div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn')!;
const mobileMenu = document.getElementById('mobile-menu')!;
const mobileLinks = document.querySelectorAll('.mobile-link');
  function toggleMenu() {
    mobileMenu.classList.toggle('hidden');
    mobileMenu.classList.toggle('flex');
  }
  menuBtn.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => {
    link.addEventListener('click', toggleMenu);
  });
</script>